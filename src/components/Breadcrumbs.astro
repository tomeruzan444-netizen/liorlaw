---
/** פירורי לחם ויזואליים. ה-Schema של BreadcrumbList נוצר ב-Base.astro. */
interface Crumb {
  title: string;
  href: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="פירורי לחם">
  <div class="container">
    <ol>
      <li><a href="/">בית</a></li>
      {
        crumbs.map((c, i) => (
          <li aria-current={i === crumbs.length - 1 ? "page" : undefined}>
            {i === crumbs.length - 1 ? c.title : <a href={c.href}>{c.title}</a>}
          </li>
        ))
      }
    </ol>
  </div>
</nav>

<style>
  .breadcrumbs {
    background: var(--gold-100);
    border-bottom: 1px solid var(--line);
    font-size: 0.92rem;
  }

  ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.55rem 0;
    margin: 0;
  }

  li {
    margin: 0;
    color: var(--ink-soft);
  }

  li + li::before {
    content: "‹";
    margin-inline-end: 0.4rem;
    color: var(--gold-500);
  }

  a {
    color: var(--navy-700);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
