---
/**
 * טופס לידים קומפקטי להירו של עמוד הבית.
 * עובד באותו מנגנון כמו ContactForm: מצב הדגמה עד שיוזן מפתח Web3Forms.
 */
const WEB3FORMS_KEY = ""; // PLACEHOLDER - אותו מפתח כמו ב-ContactForm
---

<form class="lead-form" method="POST" action="https://api.web3forms.com/submit" novalidate>
  {WEB3FORMS_KEY && <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />}
  <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />

  <p class="lead-form-title">בדיקת זכאות ראשונית - ללא עלות</p>

  <div class="lead-field">
    <label for="lf-name" class="visually-hidden">שם מלא</label>
    <input id="lf-name" name="name" type="text" placeholder="שם מלא *" required autocomplete="name" />
  </div>
  <div class="lead-field">
    <label for="lf-phone" class="visually-hidden">טלפון</label>
    <input id="lf-phone" name="phone" type="tel" placeholder="טלפון *" required autocomplete="tel" />
  </div>
  <div class="lead-field">
    <label for="lf-email" class="visually-hidden">אימייל</label>
    <input id="lf-email" name="email" type="email" placeholder="אימייל" autocomplete="email" />
  </div>

  <label class="lead-consent">
    <input type="checkbox" name="consent" required />
    <span>
      אני מאשר/ת שימוש בפרטים ליצירת קשר, בהתאם ל<a href="/privacy-policy/">מדיניות הפרטיות</a>
    </span>
  </label>

  <button type="submit" class="btn btn--gold lead-submit">שליחה - נחזור אליכם בהקדם</button>
  <p class="form-status" role="status" aria-live="polite"></p>
</form>

<style>
  .lead-form {
    background: rgba(255, 255, 255, 0.97);
    border-radius: var(--radius);
    padding: 1.6rem;
    box-shadow: 0 18px 50px rgba(0, 12, 28, 0.45);
    border-top: 4px solid var(--gold-500);
  }

  .lead-form-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--navy-800);
    margin: 0 0 1rem;
  }

  .lead-field {
    margin-bottom: 0.8rem;
  }

  input[type="text"],
  input[type="tel"],
  input[type="email"] {
    width: 100%;
    padding: 0.7rem 0.95rem;
    border: 1.5px solid var(--line);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 1rem;
    background: var(--cream);
    color: var(--ink);
  }

  input[type="tel"] {
    direction: rtl;
  }

  input:focus {
    outline: none;
    border-color: var(--gold-500);
    box-shadow: 0 0 0 3px rgba(174, 148, 117, 0.25);
  }

  .lead-consent {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .lead-consent input {
    margin-top: 0.25rem;
    accent-color: var(--gold-500);
  }

  .lead-submit {
    width: 100%;
    border: none;
  }

  .form-status {
    margin: 0.8rem 0 0;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .form-status.ok {
    color: #1a7a3a;
  }

  .form-status.err {
    color: #b3261e;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".lead-form");
  const status = form?.querySelector<HTMLElement>(".form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.reportValidity() || !status) return;

    const hasKey = !!form.querySelector('input[name="access_key"]');
    status.textContent = "שולח...";
    status.className = "form-status";

    if (!hasKey) {
      status.textContent = "תודה על פנייתכם! (הטופס עדיין לא מחובר - נחזור אליכם לאחר החיבור)";
      status.className = "form-status ok";
      form.reset();
      return;
    }

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        status.textContent = "הפנייה נשלחה בהצלחה! ניצור אתכם קשר בהקדם.";
        status.className = "form-status ok";
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      status.textContent = "אירעה שגיאה בשליחה. אפשר להתקשר אלינו ישירות או לנסות שוב.";
      status.className = "form-status err";
    }
  });
</script>
