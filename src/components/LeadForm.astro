---
/**
 * טופס לידים קומפקטי להירו של עמוד הבית.
 * עובד באותו מנגנון כמו ContactForm: מצב הדגמה עד שיוזן מפתח Web3Forms.
 */
const WEB3FORMS_KEY = ""; // PLACEHOLDER - אותו מפתח כמו ב-ContactForm
---

<form class="lead-form" method="POST" action="https://api.web3forms.com/submit" novalidate>
  {WEB3FORMS_KEY && <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />}
  <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />

  <p class="lead-form-title">בדיקת זכאות ראשונית - ללא עלות</p>

  <div class="lead-field">
    <label for="lf-name" class="visually-hidden">שם מלא</label>
    <input id="lf-name" name="name" type="text" placeholder="שם מלא *" required autocomplete="name" />
  </div>
  <div class="lead-field">
    <label for="lf-phone" class="visually-hidden">טלפון</label>
    <input id="lf-phone" name="phone" type="tel" placeholder="טלפון *" required autocomplete="tel" />
  </div>
  <div class="lead-field">
    <label for="lf-email" class="visually-hidden">אימייל</label>
    <input id="lf-email" name="email" type="email" placeholder="אימייל" autocomplete="email" />
  </div>

  <label class="lead-consent">
    <input type="checkbox" name="consent" required />
    <span>
      אני מאשר/ת שימוש בפרטים ליצירת קשר, בהתאם ל<a href="/privacy-policy/">מדיניות הפרטיות</a>
    </span>
  </label>

  <button type="submit" class="btn btn--gold lead-submit">שליחה - נחזור אליכם בהקדם</button>
  <p class="form-status" role="status" aria-live="polite"></p>
</form>

<style>
  /* כרטיס זכוכית - שקוף-כהה, משתלב בתמונת ההירו */
  .lead-form {
    background: rgba(0, 18, 40, 0.42);
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    padding: 2rem 1.8rem;
    box-shadow: 0 24px 60px rgba(0, 10, 24, 0.35);
  }

  .lead-form-title {
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--white);
    margin: 0 0 0.4rem;
  }

  /* קו זהב עדין מתחת לכותרת */
  .lead-form-title::after {
    content: "";
    display: block;
    width: 44px;
    height: 2px;
    background: var(--gold-400);
    margin-top: 0.55rem;
    margin-bottom: 1rem;
    border-radius: 2px;
  }

  .lead-field {
    margin-bottom: 0.4rem;
  }

  /* שדות מינימליסטיים - קו תחתון בלבד */
  input[type="text"],
  input[type="tel"],
  input[type="email"] {
    width: 100%;
    padding: 0.85rem 0.2rem;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 0;
    font-family: var(--font-body);
    font-size: 1.02rem;
    background: transparent;
    color: var(--white);
    transition: border-color 0.2s ease;
  }

  input::placeholder {
    color: rgba(255, 255, 255, 0.65);
  }

  input[type="tel"] {
    direction: rtl;
  }

  input:focus {
    outline: none;
    border-bottom-color: var(--gold-400);
    box-shadow: 0 1px 0 0 var(--gold-400);
  }

  .lead-consent {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 1.1rem 0 1.3rem;
    line-height: 1.5;
  }

  .lead-consent a {
    color: var(--gold-400);
  }

  .lead-consent input {
    margin-top: 0.25rem;
    accent-color: var(--gold-500);
  }

  .lead-submit {
    width: 100%;
    border: none;
    border-radius: 10px;
  }

  .form-status {
    margin: 0.8rem 0 0;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .form-status.ok {
    color: #8fe0aa;
  }

  .form-status.err {
    color: #ff9d94;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".lead-form");
  const status = form?.querySelector<HTMLElement>(".form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.reportValidity() || !status) return;

    const hasKey = !!form.querySelector('input[name="access_key"]');
    status.textContent = "שולח...";
    status.className = "form-status";

    if (!hasKey) {
      status.textContent = "תודה על פנייתכם! (הטופס עדיין לא מחובר - נחזור אליכם לאחר החיבור)";
      status.className = "form-status ok";
      form.reset();
      return;
    }

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        status.textContent = "הפנייה נשלחה בהצלחה! ניצור אתכם קשר בהקדם.";
        status.className = "form-status ok";
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      status.textContent = "אירעה שגיאה בשליחה. אפשר להתקשר אלינו ישירות או לנסות שוב.";
      status.className = "form-status err";
    }
  });
</script>
