---
/**
 * מקטע שאלות נפוצות: אקורדיון נגיש (details/summary) + Schema של FAQPage.
 * התשובות נשמרות כטקסט נקי ב-Schema כדי שמנועי חיפוש ו-AI יוכלו לצטט אותן.
 */
interface QA {
  q: string;
  a: string;
}

interface Props {
  items: QA[];
  title?: string;
}

const { items, title = "שאלות נפוצות" } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<section class="faq section" aria-labelledby="faq-title">
  <div class="container">
    <h2 id="faq-title">{title}</h2>
    <div class="faq-list">
      {
        items.map((item) => (
          <details>
            <summary>
              <h3>{item.q}</h3>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
              </svg>
            </summary>
            <p>{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-list {
    max-width: 46rem;
  }

  details {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-bottom: 0.9rem;
    overflow: hidden;
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 1.3rem;
    cursor: pointer;
    list-style: none;
    color: var(--navy-800);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary h3 {
    margin: 0;
    font-size: 1.08rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: inherit;
  }

  summary svg {
    flex-shrink: 0;
    color: var(--gold-500);
    transition: transform 0.2s ease;
  }

  details[open] summary svg {
    transform: rotate(180deg);
  }

  details[open] summary {
    border-bottom: 1px solid var(--line);
  }

  details p {
    padding: 1rem 1.3rem;
    margin: 0;
    color: var(--ink);
  }

  summary:hover {
    background: var(--gold-100);
  }
</style>
