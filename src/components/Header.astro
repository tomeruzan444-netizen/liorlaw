---
import { NAV, SITE } from "../config/site";

const current = Astro.url.pathname;
// בעמוד הבית ההדר שקוף מעל ההירו והופך לבן בגלילה
const isHome = current === "/";
---

<header class:list={["site-header", { overlay: isHome }]}>
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="ליאור עייש - משרד עורכי דין, מעבר לעמוד הבית">
      <img
        class="logo-navy"
        src="/images/logo-horizontal-navy.png"
        alt="ליאור עייש - משרד עורכי דין"
        width="220"
        height="71"
        fetchpriority="high"
      />
      {isHome && (
        <img
          class="logo-white"
          src="/images/logo-horizontal-white.png"
          alt=""
          width="220"
          height="71"
          fetchpriority="high"
        />
      )}
    </a>

    <nav class="main-nav" aria-label="ניווט ראשי">
      <button
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="פתיחת תפריט"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>

      <ul id="nav-menu" class="nav-menu">
        {
          NAV.map((item) =>
            "children" in item && item.children ? (
              <li class="has-sub">
                <button class="sub-toggle" aria-expanded="false">
                  {item.title}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                  </svg>
                </button>
                <ul class="sub-menu">
                  {item.children.map((c) => (
                    <li>
                      <a href={c.href} aria-current={current === c.href ? "page" : undefined}>
                        {c.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a href={item.href} aria-current={current === item.href ? "page" : undefined}>
                  {item.title}
                </a>
              </li>
            )
          )
        }
        <li class="nav-phone">
          <a href={`tel:${SITE.phoneIntl}`} aria-label="חיוג למשרד">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
            <bdo dir="ltr">{SITE.phone}</bdo>
          </a>
        </li>
        <li class="nav-cta">
          <a href="/contact/" class="btn btn--gold">יצירת קשר</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0, 38, 79, 0.06);
    transition: background 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .logo-white {
    display: none;
  }

  /* בעמוד הבית: הדר שקוף שמרחף מעל ההירו, עד שגוללים */
  .site-header.overlay {
    position: fixed;
    inset-inline: 0;
    top: 0;
  }

  .site-header.overlay:not(.solid) {
    background: transparent;
    border-bottom-color: rgba(255, 255, 255, 0.16);
    box-shadow: none;
  }

  .overlay:not(.solid) .logo-navy {
    display: none;
  }

  .overlay:not(.solid) .logo-white {
    display: block;
  }

  .overlay:not(.solid) .nav-menu a:not(.btn),
  .overlay:not(.solid) .sub-toggle,
  .overlay:not(.solid) .nav-phone a {
    color: #f0f4f9;
  }

  .overlay:not(.solid) .nav-menu a:not(.btn):hover,
  .overlay:not(.solid) .sub-toggle:hover {
    color: var(--gold-400);
  }

  .overlay:not(.solid) .nav-toggle-bar {
    background: #fff;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.6rem;
  }

  .logo-link {
    flex-shrink: 0;
    display: block;
  }

  .logo-link img {
    width: clamp(160px, 22vw, 220px);
    height: auto;
  }

  .main-nav {
    flex-grow: 1;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* הטלפון והכפתור נצמדים לקצה - הקישורים נשארים ממורכזים */
  .nav-phone {
    margin-inline-start: auto;
  }

  .nav-menu li {
    margin: 0;
  }

  .nav-menu a:not(.btn),
  .sub-toggle {
    color: var(--navy-800);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.02rem;
    padding: 0.4rem 0.1rem;
    position: relative;
  }

  /* קו תחתון שנפתח מהמרכז בהובר */
  .nav-menu > li > a:not(.btn)::after,
  .sub-toggle::after {
    content: "";
    position: absolute;
    bottom: 0;
    inset-inline: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--gold-500);
    transform: scaleX(0);
    transition: transform 0.22s ease;
  }

  .nav-menu > li > a:not(.btn):hover::after,
  .sub-toggle:hover::after,
  .nav-menu > li > a[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .nav-menu a:not(.btn):hover,
  .sub-toggle:hover {
    color: var(--gold-500);
  }

  .nav-menu a[aria-current="page"] {
    color: var(--gold-500);
  }

  .nav-cta .btn {
    padding: 0.5rem 1.3rem;
    font-size: 1rem;
  }

  .nav-phone a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 700 !important;
  }

  .nav-phone svg {
    color: var(--gold-500);
  }

  /* תפריט משנה */
  .has-sub {
    position: relative;
  }

  .sub-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
  }

  .sub-menu {
    position: absolute;
    top: 100%;
    inset-inline-start: 0;
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
    padding: 0.5rem 0;
    margin: 0;
    list-style: none;
    min-width: 270px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }

  .has-sub:hover .sub-menu,
  .has-sub:focus-within .sub-menu,
  .has-sub.open .sub-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .sub-menu a {
    display: block;
    padding: 0.55rem 1.2rem !important;
    font-weight: 500 !important;
  }

  .sub-menu a:hover {
    background: var(--gold-100);
  }

  /* המבורגר */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
  }

  .nav-toggle-bar {
    width: 26px;
    height: 3px;
    background: var(--navy-800);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 900px) {
    .nav-toggle {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      inset-inline: 0;
      background: var(--white);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1.25rem 1.25rem;
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-lift);
      display: none;
    }

    .nav-menu.open {
      display: flex;
    }

    .nav-menu a:not(.btn),
    .sub-toggle {
      display: block;
      width: 100%;
      text-align: start;
      padding: 0.75rem 0;
      font-size: 1.1rem;
      border-bottom: 1px solid var(--line);
    }

    .sub-menu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      padding: 0;
      display: none;
      background: var(--gold-100);
      border-radius: 8px;
    }

    .has-sub.open .sub-menu {
      display: block;
    }

    .nav-cta {
      margin-top: 1rem;
    }

    .nav-cta .btn {
      display: block;
      text-align: center;
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.getElementById("nav-menu");
  const header = document.querySelector(".site-header");

  // הדר שקוף בעמוד הבית: הופך לבן בגלילה או כשהתפריט פתוח
  const syncHeader = () => {
    if (!header?.classList.contains("overlay")) return;
    header.classList.toggle(
      "solid",
      window.scrollY > 24 || !!menu?.classList.contains("open")
    );
  };
  window.addEventListener("scroll", syncHeader, { passive: true });
  syncHeader();

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
    toggle.setAttribute("aria-label", open ? "סגירת תפריט" : "פתיחת תפריט");
    syncHeader();
  });

  document.querySelectorAll(".sub-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const li = btn.closest(".has-sub");
      const open = li?.classList.toggle("open");
      btn.setAttribute("aria-expanded", String(!!open));
    });
  });
</script>
