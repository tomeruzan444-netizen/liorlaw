---
import { SITE } from "../config/site";
---

<a
  href={SITE.whatsapp}
  class="wa-float"
  target="_blank"
  rel="noopener"
  aria-label="שליחת הודעת וואטסאפ למשרד"
>
  <svg viewBox="0 0 32 32" width="30" height="30" fill="currentColor" aria-hidden="true">
    <path
      d="M16 2.9C8.8 2.9 3 8.7 3 15.9c0 2.3.6 4.5 1.7 6.5L3 29.1l6.9-1.8c1.9 1 4 1.6 6.1 1.6 7.2 0 13-5.8 13-13S23.2 2.9 16 2.9zm0 23.7c-1.9 0-3.8-.5-5.4-1.5l-.4-.2-4.1 1.1 1.1-4-.3-.4c-1.1-1.7-1.6-3.7-1.6-5.7C5.3 10 10.1 5.2 16 5.2S26.7 10 26.7 15.9 21.9 26.6 16 26.6zm5.9-8c-.3-.2-1.9-.9-2.2-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.4-.5-2.6-1.6-1-.9-1.6-1.9-1.8-2.3-.2-.3 0-.5.1-.6l.5-.6c.2-.2.2-.3.3-.6.1-.2 0-.4 0-.6-.1-.2-.7-1.8-1-2.4-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.2 1.3 3.4c.2.2 2.3 3.5 5.5 4.9.8.3 1.4.5 1.9.7.8.2 1.5.2 2.1.1.6-.1 1.9-.8 2.2-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.6-.4z"
    />
  </svg>
</a>

<style>
  .wa-float {
    position: fixed;
    bottom: 1.4rem;
    inset-inline-start: 1.4rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #23b858;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(255, 255, 255, 0.85);
    box-shadow: 0 5px 18px rgba(0, 16, 39, 0.3);
    z-index: 90;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .wa-float svg {
    width: 26px;
    height: 26px;
  }

  .wa-float:hover {
    transform: scale(1.07);
    box-shadow: 0 8px 24px rgba(0, 16, 39, 0.4);
    color: #fff;
  }
</style>
