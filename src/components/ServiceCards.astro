---
/** רשת כרטיסי תחומי עיסוק - לשימוש בעמוד הבית ובעמוד אודות. */
import { SERVICES } from "../config/site";

interface Props {
  title?: string;
  /** נתיב לעמוד שאין להציג (למשל בעמוד שירות - לא מציגים את עצמו) */
  exclude?: string;
}

const { title = "תחומי העיסוק שלנו", exclude } = Astro.props;
const services = SERVICES.filter((s) => s.href !== exclude);
---

<section class="section" aria-labelledby="services-title">
  <div class="container">
    <h2 id="services-title">{title}</h2>
    <div class="grid grid--3">
      {
        services.map((s) => (
          <a class="card service-card" href={s.href}>
            <h3>{s.title}</h3>
            <p>{s.short}</p>
            <span class="more">למידע נוסף ←</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .service-card {
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    border-top: 3px solid var(--gold-500);
  }

  .service-card h3 {
    margin-bottom: 0.4em;
  }

  .service-card p {
    margin-bottom: 1em;
    color: var(--ink-soft);
    flex-grow: 1;
  }

  .more {
    color: var(--gold-500);
    font-weight: 600;
  }

  .service-card:hover .more {
    text-decoration: underline;
  }

  .service-card:hover h3 {
    color: var(--navy-700);
  }
</style>
