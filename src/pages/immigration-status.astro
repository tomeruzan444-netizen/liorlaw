---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "בן/בת הזוג שלי אינם אזרחי ישראל. איך מסדירים להם מעמד?",
    a: "זוגות נשואים נכנסים להליך מדורג של כמה שנים, שבסופו ניתן לקבל תושבות קבע או אזרחות; ידועים בציבור נכנסים להליך מדורג ארוך יותר. בשני המסלולים נדרש להוכיח כנות קשר ומרכז חיים בישראל, והטיפול רצוף בקשות מסמכים, ראיונות והחלטות ביניים - ליווי מקצועי חוסך עיכובים של חודשים.",
  },
  {
    q: "מה עושים כשרשות האוכלוסין דוחה בקשה?",
    a: "החלטת סירוב אינה סוף הדרך: ניתן להגיש השגה פנימית, ערר לבית הדין לעררים לענייני הגירה, ובמקרים מתאימים עתירה מנהלית. לכל הליך מועדים קצובים וקצרים - חשוב לפעול מיד עם קבלת ההחלטה.",
  },
  {
    q: "אני תושב חוץ ורוצה לעבוד או לשהות בישראל לתקופה ארוכה. מה האפשרויות?",
    a: "בהתאם לנסיבות: אשרות עבודה (ב/1) למומחים ולעובדים זרים, אשרות שהייה מכוח קשר משפחתי, מעמד מכוח שבות ליהודים ובני משפחותיהם, ואשרות מיוחדות נוספות. נבחן יחד את המסלול המתאים ונלווה את הבקשה מול הרשויות עד לקבלת המעמד.",
  },
  {
    q: "כמה זמן אורך הליך הסדרת מעמד?",
    a: "תלוי במסלול: הליכים מדורגים לבני זוג נמשכים שנים על פי נוהל, אך משך הטיפול בפועל מושפע מאוד מאיכות התיק - תיק מלא ומסודר שמוגש נכון מהפעם הראשונה חוסך סבבי השלמות ודחיות. בערר או בעתירה, לוחות הזמנים קצרים ומחייבים תגובה מהירה.",
  },
];
---

<ServicePage
  title="הסדרת מעמד והגירה בישראל | עורך דין מעמד לתושבי חוץ - ליאור עייש"
  description="הסדרת מעמד בישראל לתושבי חוץ: איחוד משפחות ומעמד לבני זוג זרים, אשרות עבודה ושהייה, תושבות ואזרחות, עררים ועתירות נגד רשות האוכלוסין. ליווי משפטי מלא."
  path="/immigration-status/"
  crumbTitle="מעמד והגירה"
  heroTitle="הסדרת מעמד והגירה בישראל"
  heroSubtitle="מעמד לבני זוג זרים, אשרות שהייה ועבודה, תושבות ואזרחות - ליווי מלא מול רשות האוכלוסין וההגירה."
  faq={faq}
  ctaTitle="צריכים להסדיר מעמד בישראל?"
  ctaText="ספרו לנו את הסיפור - ונתווה יחד את המסלול הנכון, עם תמונה ברורה של השלבים והסיכויים."
>
  <h2>מעמד בישראל - תחום שבו הבירוקרטיה מכריעה גורלות</h2>
  <p>
    <strong>הסדרת מעמד בישראל</strong> היא תחום משפטי-מנהלי שבו החלטה של פקיד
    יכולה להפריד בין בני זוג, לעצור קריירה או להשאיר אדם ללא מעמד חוקי.
    ההליכים מול רשות האוכלוסין וההגירה ידועים כמורכבים, איטיים ורוויי
    דרישות - וטעות אחת בתיק יכולה לעלות בשנים של עיכוב.
  </p>
  <p>
    המשרד מלווה תושבי חוץ, בני זוג זרים ומשפחות בכל שלבי ההליך: מבניית התיק
    והגשתו, דרך ראיונות והשלמות, ועד עררים ועתירות כשההחלטה אינה מוצדקת.
  </p>

  <h2>במה אנחנו מטפלים?</h2>
  <ul>
    <li><strong>מעמד לבני זוג זרים</strong> - נשואים וידועים בציבור, בהליך המדורג ועד תושבות ואזרחות</li>
    <li><strong>איחוד משפחות</strong> - הורים קשישים, ילדים ובני משפחה נוספים</li>
    <li><strong>אשרות שהייה ועבודה</strong> - מומחים זרים, עובדים ומבקרים לתקופות ארוכות</li>
    <li><strong>מעמד מכוח חוק השבות</strong> - עלייה, הוכחת זכאות וטיפול בסירובים</li>
    <li><strong>עררים ועתירות</strong> - השגות, בית הדין לעררים לענייני הגירה ועתירות מנהליות</li>
    <li><strong>מניעת הרחקה</strong> - טיפול דחוף במקרים של סירוב כניסה או צו הרחקה</li>
  </ul>

  <h2>איך נראה הליך מוצלח?</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>שלב</th>
          <th>מה אנחנו עושים</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1. אבחון</td>
          <td>מיפוי הנסיבות ובחירת המסלול הנכון - החלטה שקובעת את כל ההמשך</td>
        </tr>
        <tr>
          <td>2. בניית התיק</td>
          <td>איסוף ראיות לכנות הקשר ומרכז החיים, תרגומים, אימותים ותצהירים</td>
        </tr>
        <tr>
          <td>3. הגשה וליווי</td>
          <td>הגשה מסודרת, מעקב אחר הטיפול, הכנה לראיונות וליווי בהם</td>
        </tr>
        <tr>
          <td>4. מעקב והתקדמות</td>
          <td>שדרוג המעמד בכל שלב בהליך המדורג, עד תושבות או אזרחות</td>
        </tr>
        <tr>
          <td>5. ערר בעת הצורך</td>
          <td>תגובה מהירה לסירובים - השגה, ערר או עתירה בתוך המועדים</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>למה חשוב ליווי משפטי כבר מההתחלה?</h2>
  <p>
    רוב התיקים שנתקעים - נתקעים בגלל הגשה ראשונית חסרה: מסמך שלא צורף, טופס
    שמולא לא נכון, או ראיות שלא סודרו כפי שהרשות מצפה. תיק שנבנה נכון מהיום
    הראשון עובר מהר יותר, ומקטין דרמטית את הסיכון לסירוב. ואם כבר קיבלתם
    סירוב - אל תוותרו: חלק גדול מההחלטות משתנות בערר מנומק.
  </p>
  <p>
    יש לכם שאלה על המצב שלכם? <a href="/contact/">דברו איתנו</a> - נבחן את
    המקרה וניתן תשובה כנה על המסלול והסיכויים.
  </p>
</ServicePage>
