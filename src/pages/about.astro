---
import Base from "../layouts/Base.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Hero from "../components/Hero.astro";
import ServiceCards from "../components/ServiceCards.astro";
import CTA from "../components/CTA.astro";

const crumbs = [{ title: "אודות", href: "/about/" }];
const pageTitle = 'אודות עו"ד ליאור עייש | לשעבר סגן התובע הצבאי הראשי';
const pageDesc =
  'הכירו את עו"ד ליאור עייש: למעלה מ-14 שנות ניסיון במשפט הפלילי והצבאי, שירות בדרגת סגן אלוף בפרקליטות הצבאית ובסנגוריה הצבאית, ותפקידי מפתח בהם סגן התובע הצבאי הראשי ופרקליט מחוז מטכ"ל.';
---

<Base title={pageTitle} description={pageDesc} path="/about/" breadcrumbs={crumbs}>
  <Breadcrumbs crumbs={crumbs} />
  <Hero
    title='אודות עו"ד ליאור עייש'
    subtitle="למעלה מ-14 שנות ניסיון בחזית המשפט הפלילי והצבאי - מהפרקליטות הצבאית ועד ייצוג לקוחות ברגעים המכריעים ביותר."
  />

  <article class="section">
    <div class="container prose">
      <h2>מי אנחנו</h2>
      <p>
        <strong>עו"ד ליאור עייש</strong> הוא משפטן מנוסה, בעל למעלה מ-14 שנות
        ניסיון בחזית עולם המשפט הפלילי והצבאי. עו"ד עייש מתמחה בליטיגציה
        מורכבת, בניהול אסטרטגיה משפטית ובניהול משברים ברגעים המכריעים ביותר.
      </p>

      <h2>למעלה מעשור בתפקידי מפתח בכירים במערכת</h2>
      <p>
        בעברו שירת עו"ד עייש בדרגת <strong>סגן אלוף</strong> בפרקליטות הצבאית
        ובסנגוריה הצבאית, ומילא שורה של תפקידי מפתח בכירים, בהם:
      </p>
      <ul>
        <li>סגן התובע הצבאי הראשי</li>
        <li>פרקליט מחוז מטכ"ל</li>
        <li>הפרקליט לעניינים מבצעיים</li>
      </ul>
      <p>
        היכרותו המעמיקה עם המערכת - הן מכובע התביעה והן מכובע הסנגוריה - מעניקה
        לו נקודת מבט ייחודית ויתרון אסטרטגי חסר פשרות בייצוג לקוחות המשרד.
      </p>

      <h2>השכלה אקדמית</h2>
      <ul>
        <li>תואר ראשון במשפטים (LL.B) - האוניברסיטה העברית בירושלים</li>
        <li>תואר שני (M.A) בדיפלומטיה וביטחון - אוניברסיטת תל-אביב</li>
      </ul>

      <h2>תחומי המומחיות של המשרד</h2>
      <p>
        משרדנו מספק מעטפת משפטית מקיפה וייצוג בפני כל ערכאות השיפוט וכל מוסדות
        המדינה:
      </p>
      <ul>
        <li>
          <a href="/criminal-law/"><strong>משפט פלילי</strong></a> - ייצוג
          וטיפול בתיקים חמורים ומורכבים: עבירות מין, עבירות נשק, עבירות
          המתה ועבירות רשלנות.
        </li>
        <li>
          <a href="/white-collar/"><strong>עבירות צווארון לבן</strong></a> -
          מרמה, עבירות מס, הלבנת הון ועבירות ניירות ערך.
        </li>
        <li>
          <a href="/military-law/"><strong>דיני צבא וביטחון</strong></a> -
          ייצוג מול רשויות הצבא, הסדרי מעמד וערעור על קביעות רפואיות.
        </li>
        <li>
          <a href="/immigration-status/"><strong>מעמד והגירה</strong></a> -
          הסדרת מעמד בישראל לתושבי חוץ ולבני זוג זרים.
        </li>
        <li>
          <a href="/crime-victims/"><strong>נפגעות ונפגעי עבירה</strong></a> -
          מימוש זכויות בהליך הפלילי ותביעות פיצויים.
        </li>
        <li>
          <strong>פגיעה אגב שירות סדיר או מילואים</strong> - ייצוג
          ב<a href="/mod-claims/">תביעות מול משרד הביטחון</a> והכרה כנכי
          צה"ל, לרבות <a href="/ptsd-lawyer/">הכרה בפוסט-טראומה</a>
          ו<a href="/pension-officer-appeal/">ערעורים על החלטות קצין התגמולים</a>.
        </li>
        <li>
          <strong>נפגעי תאונות עבודה</strong> - ייצוג והכרה מול הביטוח
          הלאומי, כולל <a href="/medical-committee/">ליווי בוועדות הרפואיות</a>.
        </li>
      </ul>

      <h2>הגישה שלנו</h2>
      <ul>
        <li><strong>הקשבה לפני הכול</strong> - כל תיק מתחיל בשיחה יסודית, בגובה העיניים ובקצב שלכם.</li>
        <li><strong>שקיפות מלאה</strong> - הערכה כנה של סיכויי התיק, שכר טרחה ברור מראש, ועדכון שוטף בכל שלב.</li>
        <li><strong>אסטרטגיה לפני הגשה</strong> - איסוף תיעוד קפדני וחוות דעת מתאימות, לפני שהתיק מוגש.</li>
        <li><strong>ליווי עד הסוף</strong> - כולל הכנה אישית לוועדות הרפואיות והתייצבות לצדכם בהן.</li>
      </ul>
    </div>
  </article>

  <ServiceCards title="תחומי העיסוק המרכזיים באתר" />
  <CTA
    title="רוצים לבדוק את המקרה שלכם?"
    text="ספרו לנו מה עברתם - ונחזור אליכם עם תשובה כנה האם וכיצד נוכל לעזור. השיחה הראשונה עלינו."
  />
</Base>
