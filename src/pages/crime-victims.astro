---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "אילו זכויות יש לנפגעי עבירה בהליך הפלילי?",
    a: "חוק זכויות נפגעי עבירה מקנה שורת זכויות: לקבל מידע על התקדמות ההליך, להביע עמדה לפני הסדר טיעון ובקשות חנינה, להיות מוגנים מפני הנאשם, ולהגיש הצהרת נפגע שמובאת בחשבון בגזירת הדין. בעבירות מין ואלימות חמורה הזכויות רחבות עוד יותר. בפועל - זכויות רבות לא ממומשות אם אין מי שעומד עליהן.",
  },
  {
    q: "התיק נסגר בלי כתב אישום. אפשר לעשות משהו?",
    a: "כן. לנפגע עבירה עומדת זכות ערר על החלטה לסגור תיק - לפרקליטות או למשטרה, לפי הגורם שסגר. ערר מנומק, שמצביע על ראיות שלא מוצו או על שיקולים שגויים, מוביל לא פעם לפתיחת התיק מחדש. המועדים קצובים, ולכן חשוב לפעול מהר.",
  },
  {
    q: "האם אפשר לקבל פיצוי כספי מהפוגע?",
    a: "בשני מסלולים: בית המשפט הפלילי מוסמך לפסוק פיצוי לנפגע כבר בגזר הדין, ובנוסף ניתן להגיש תביעה אזרחית - כולל תביעה אזרחית נגררת להרשעה בפלילים, שבה ההרשעה משמשת ראיה מכרעת ומקצרת את הדרך לפיצוי.",
  },
  {
    q: "אני חוששת מעימות עם הפוגע במהלך ההליך. איך מגינים עליי?",
    a: "החוק מעניק הגנות ייעודיות: עדות בדרכים מותאמות, הרחקת הנאשם, איסורי פרסום, וליווי לאורך ההליך. בעבירות מין קיימות הגנות נוספות על פרטיות הנפגעת. אנחנו דואגים שההגנות האלה ימומשו בפועל - ולא יישארו על הנייר.",
  },
];
---

<ServicePage
  title="ייצוג נפגעות ונפגעי עבירה | מיצוי זכויות מול הפוגע והמערכת - ליאור עייש"
  description="ליווי משפטי לנפגעות ונפגעי עבירה: מימוש זכויות בהליך הפלילי, ערר על סגירת תיק, הצהרת נפגע, הגנות בעדות ותביעות פיצויים - ברגישות ובנחישות."
  path="/crime-victims/"
  crumbTitle="נפגעי עבירה"
  heroTitle="ייצוג נפגעות ונפגעי עבירה"
  heroSubtitle="עברתם פגיעה - ואתם לא צד להליך? החוק מעניק לכם זכויות ממשיות. אנחנו נדאג שהן ימומשו."
  faq={faq}
  ctaTitle="נפגעתם מעבירה?"
  ctaText="אתם לא חייבים לעבור את ההליך לבד מהיציע. שיחה ראשונה - רגישה, דיסקרטית וללא התחייבות."
>
  <h2>לנפגעי עבירה יש קול - וצריך מי שישמיע אותו</h2>
  <p>
    ההליך הפלילי מתנהל בין המדינה לנאשם - ומי שנפגעו בפועל מוצאים את עצמם
    לא פעם בשוליים: בלי מידע, בלי השפעה ובלי ליווי. אבל המצב המשפטי שונה:
    <strong>חוק זכויות נפגעי עבירה</strong> מעניק לנפגעות ולנפגעים מעמד
    וזכויות ממשיות לאורך כל ההליך - מהחקירה ועד גזר הדין ואחריו.
  </p>
  <p>
    הניסיון של עו"ד ליאור עייש כתובע בכיר - מי שניהל תיקים מול נפגעי עבירה
    וראה מקרוב מה קורה כשאין להם ייצוג - הוא הבסיס לליווי שאנחנו נותנים:
    יודעים בדיוק אילו זכויות קיימות, מול מי עומדים עליהן, ואיך מוודאים שהקול
    שלכם נשמע בכל צומת החלטה.
  </p>

  <h2>מה אנחנו עושים עבורכם?</h2>
  <ul>
    <li><strong>מימוש זכויות בהליך</strong> - קבלת מידע שוטף, עמדה לפני הסדרי טיעון ועדכון בכל החלטה</li>
    <li><strong>ערר על סגירת תיק</strong> - כשהמשטרה או הפרקליטות גונזות את התלונה</li>
    <li><strong>הצהרת נפגע</strong> - ניסוח והגשה של מסמך ההשפעה על העונש</li>
    <li><strong>הגנות בעדות</strong> - עדות מותאמת, איסורי פרסום והגנה על הפרטיות</li>
    <li><strong>פיצויים</strong> - פיצוי בהליך הפלילי ותביעה אזרחית נגררת להרשעה</li>
    <li><strong>ליווי אישי</strong> - הסבר על כל שלב, הכנה לעדות ונוכחות לצדכם בדיונים</li>
  </ul>

  <h2>המסלולים לפיצוי - במבט אחד</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>מסלול</th>
          <th>מתי מתאים</th>
          <th>יתרון</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>פיצוי בגזר הדין</td>
          <td>עם הרשעת הפוגע בהליך הפלילי</td>
          <td>ללא צורך בתביעה נפרדת - נפסק ישירות</td>
        </tr>
        <tr>
          <td>תביעה אזרחית נגררת</td>
          <td>לאחר הרשעה, לפיצוי מלא יותר</td>
          <td>ההרשעה משמשת ראיה - הליך קצר וממוקד</td>
        </tr>
        <tr>
          <td>תביעה אזרחית עצמאית</td>
          <td>גם כשאין הרשעה או כשהתיק נסגר</td>
          <td>נטל הוכחה אזרחי, נמוך מהפלילי</td>
        </tr>
        <tr>
          <td>נפגעי פעולות איבה</td>
          <td>כשהפגיעה היא ממעשה טרור</td>
          <td>מסלול ייעודי מול המדינה - <a href="/terror-victims/">פרטים כאן</a></td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ברגישות - ובנחישות</h2>
  <p>
    אנחנו יודעים שמאחורי כל תיק כזה יש כאב אמיתי, ולעיתים טראומה. הליווי
    שלנו מותאם לכך: בקצב שלכם, בשפה ברורה, בלי לחייב אתכם לספר את הסיפור
    יותר פעמים מהנדרש. ומול המערכת והפוגע - אנחנו הקול הנחוש שלכם. אם
    הפגיעה הותירה גם חותם נפשי, ייתכן שרלוונטי לקרוא גם על
    <a href="/ptsd-lawyer/">הכרה בפוסט-טראומה</a>.
  </p>
  <p>
    <a href="/contact/">צרו קשר</a> - כל פנייה מטופלת בדיסקרטיות מלאה.
  </p>
</ServicePage>
