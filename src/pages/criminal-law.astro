---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "זומנתי לחקירה במשטרה. מה לעשות?",
    a: "הכלל החשוב ביותר: לא להגיע לחקירה בלי ייעוץ משפטי מוקדם. לכל נחקר עומדת הזכות להיוועץ בעורך דין לפני החקירה, ומה שנאמר בחדר החקירות מלווה את התיק עד סופו. שיחת ייעוץ קצרה לפני החקירה יכולה לשנות את גורל התיק כולו - התקשרו אלינו לפני שאתם נכנסים לחדר.",
  },
  {
    q: "מה ההבדל בין עיכוב, מעצר ימים ומעצר עד תום ההליכים?",
    a: "עיכוב הוא השהיה קצרה לצורך בירור (עד שלוש שעות ככלל). מעצר ימים הוא מעצר לצורכי חקירה באישור בית משפט, המוארך מעת לעת. מעצר עד תום ההליכים מתבקש לאחר הגשת כתב אישום. בכל אחד מהשלבים יש לסנגור כלים אחרים לפעול לשחרור - ולכן חשוב ליווי מקצועי מהרגע הראשון.",
  },
  {
    q: "האם אפשר לסגור תיק פלילי בלי כתב אישום?",
    a: "כן, ובמקרים רבים זו המטרה המרכזית: הליך שימוע לפני הגשת כתב אישום, בקשות לסגירת תיק מחוסר ראיות או מחוסר עניין לציבור, והסדרים מותנים - כולם כלים שיכולים לסיים את ההליך בלי אישום ובלי רישום פלילי מכביד. הזמן קריטי: את רוב הכלים האלה מפעילים לפני שהוגש כתב האישום.",
  },
  {
    q: "מה חשיבות הניסיון של עורך הדין בתיקים חמורים?",
    a: 'בתיקים של עבירות מין, נשק, המתה או רשלנות - עומק הניסיון הוא ההבדל. עו"ד ליאור עייש ניהל וליווה תיקים חמורים ומורכבים משני צידי המתרס: כתובע בכיר שיודע איך התביעה בונה תיק, וכסנגור שיודע היכן היא חשופה. נקודת המבט הכפולה הזו מתורגמת לאסטרטגיית הגנה מדויקת.',
  },
  {
    q: "כמה עולה ייצוג בתיק פלילי?",
    a: "שכר הטרחה תלוי במורכבות התיק ובשלב שבו הוא נמצא - חקירה, שימוע או משפט. בשיחת הייעוץ הראשונית נבין את התמונה, ניתן הערכה כנה של המצב ונציג הצעה ברורה ושקופה מראש, בלי הפתעות.",
  },
];
---

<ServicePage
  title="עורך דין פלילי | ייצוג בתיקים חמורים ומורכבים - ליאור עייש"
  description='עורך דין פלילי בכיר: ייצוג בחקירות, מעצרים, שימועים ומשפטים - עבירות מין, נשק, המתה ורשלנות. עו"ד ליאור עייש, לשעבר סגן התובע הצבאי הראשי, מכיר את שני צידי המתרס.'
  path="/criminal-law/"
  crumbTitle="משפט פלילי"
  heroTitle="משפט פלילי"
  heroSubtitle="כשהחירות שלכם על הכף, הניסיון קובע: ייצוג בחקירות, מעצרים ומשפטים - על ידי מי שהיה בצד השני של המתרס."
  faq={faq}
  ctaTitle="זומנתם לחקירה? נפתח נגדכם תיק?"
  ctaText="השעות הראשונות קריטיות. התקשרו לפני שאתם מדברים עם מישהו אחר - שיחת הייעוץ דיסקרטית וללא התחייבות."
>
  <h2>ייצוג פלילי ברגעים המכריעים ביותר</h2>
  <p>
    הליך פלילי הוא אחד הרגעים המטלטלים בחיים: חקירה במשטרה, מעצר, כתב אישום -
    כל החלטה בהם משפיעה על החירות, על שם טוב ועל העתיד המקצועי והמשפחתי.
    בדיוק ברגעים האלה נדרש סנגור שמכיר את המערכת מבפנים.
  </p>
  <p>
    <strong>עו"ד ליאור עייש</strong> מביא לתיקים הפליליים נקודת מבט נדירה:
    למעלה מ-14 שנות ניסיון משני צידי המתרס - כתובע בכיר בדרגת סגן אלוף, בהן
    סגן התובע הצבאי הראשי ופרקליט מחוז מטכ"ל, וכסנגור. מי שבנה תיקי תביעה
    יודע בדיוק היכן הם נסדקים.
  </p>

  <blockquote>
    <p>מי שבנה תיקי תביעה במשך למעלה מעשור - יודע בדיוק היכן הם נסדקים.</p>
  </blockquote>

  <h2>באילו תיקים אנחנו מטפלים?</h2>
  <ul>
    <li><strong>עבירות מין</strong> - ייצוג רגיש ודיסקרטי בתיקים מורכבים, משלב החקירה ועד ההכרעה</li>
    <li><strong>עבירות נשק</strong> - החזקה, סחר, ירי - תחום שבו לניסיון הצבאי של המשרד יתרון ייחודי</li>
    <li><strong>עבירות המתה</strong> - רצח, הריגה וגרימת מוות ברשלנות</li>
    <li><strong>עבירות רשלנות</strong> - תיקים מקצועיים ומבצעיים שבהם נבחנת התנהלות בדיעבד</li>
    <li><strong>אלימות, סמים ועבירות רכוש</strong> - בכל הערכאות</li>
    <li>וכן <a href="/white-collar/">עבירות צווארון לבן</a> ו<a href="/military-law/">עבירות בדין הצבאי</a></li>
  </ul>

  <h2>השלבים בהליך הפלילי - ומה אפשר לעשות בכל אחד</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>שלב</th>
          <th>מה קורה</th>
          <th>מה סנגור טוב עושה</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>חקירה</td>
          <td>זימון או מעצר, חקירה באזהרה</td>
          <td>ייעוץ לפני חקירה, ליווי צמוד, שמירה על הזכויות</td>
        </tr>
        <tr>
          <td>מעצר</td>
          <td>דיוני הארכת מעצר בבית המשפט</td>
          <td>מאבק על שחרור או חלופת מעצר</td>
        </tr>
        <tr>
          <td>שימוע</td>
          <td>הזדמנות לשכנע שלא להגיש כתב אישום</td>
          <td>טיעון מנומק שיכול לסגור את התיק כאן</td>
        </tr>
        <tr>
          <td>משפט</td>
          <td>הוכחות, חקירות עדים, סיכומים</td>
          <td>ניהול אסטרטגי של ההגנה עד לזיכוי או לתוצאה המיטבית</td>
        </tr>
        <tr>
          <td>גזר דין וערעור</td>
          <td>טיעונים לעונש, ערעור במידת הצורך</td>
          <td>מזעור הפגיעה - עונש, רישום פלילי והשלכות נלוות</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>למה דווקא אנחנו?</h2>
  <ul>
    <li><strong>ניסיון משני הצדדים</strong> - אסטרטגיית הגנה שנבנית מתוך הבנה איך התביעה חושבת</li>
    <li><strong>זמינות ברגעי אמת</strong> - חקירות ומעצרים לא מחכים לשעות הפעילות</li>
    <li><strong>דיסקרטיות מוחלטת</strong> - השם הטוב שלכם הוא חלק מההגנה</li>
    <li><strong>ליטיגציה מורכבת</strong> - ניהול משברים והתמודדות עם תיקים כבדים היא הליבה של המשרד</li>
  </ul>
  <p>
    ככל שפונים מוקדם יותר - כך מרחב הפעולה גדול יותר.
    <a href="/contact/">צרו קשר עכשיו</a> לשיחה דיסקרטית.
  </p>
</ServicePage>
