---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "קיבלתי זימון לחקירה ברשות מס או ברשות ניירות ערך. מה עושים?",
    a: "לא מגיעים לחקירה בלי הכנה - נקודה. חקירות צווארון לבן נבנות חודשים מראש על ידי חוקרים מיומנים, והנחקר שמגיע 'רק להסביר' מגלה שהסבריו הפכו לראיות. פנו אלינו לפני החקירה - הייעוץ המוקדם הוא חלק מהזכויות שלכם ולעיתים ההחלטה החשובה בתיק.",
  },
  {
    q: "מה נחשב עבירת צווארון לבן?",
    a: "עבירות כלכליות שמבוצעות ללא אלימות, בדרך כלל בהקשר עסקי או ציבורי: מרמה והונאה, עבירות מס, הלבנת הון, שוחד, זיוף מסמכים, עבירות ניירות ערך והפרות אמונים. המשותף להן: הן מבוססות כמעט תמיד על מסמכים ומומחיות פיננסית - ולכן ההגנה בהן דורשת שליטה בפרטים.",
  },
  {
    q: "האם אפשר לסיים תיק כלכלי בלי הרשעה?",
    a: "במקרים רבים כן: שימוע לפני כתב אישום, הסדרים מותנים, כופר בעבירות מס, והסדרי טיעון שמצמצמים את האישומים. ככל שהליווי המשפטי מתחיל מוקדם יותר - כך נשמרות יותר אפשרויות לסיום ההליך בלי הרשעה פלילית.",
  },
  {
    q: "מה ההשלכות של תיק צווארון לבן מעבר לעונש?",
    a: "לעיתים ההשלכות הנלוות כבדות מהעונש עצמו: פגיעה במוניטין, פסילה מכהונה כדירקטור, שלילת רישיונות מקצועיים, חילוט כספים ונכסים. אסטרטגיית הגנה טובה מביאה בחשבון את התמונה המלאה - לא רק את השאלה המשפטית הצרה.",
  },
];
---

<ServicePage
  title="עורך דין צווארון לבן | עבירות כלכליות, מס והלבנת הון - ליאור עייש"
  description="ייצוג בעבירות צווארון לבן: מרמה והונאה, עבירות מס, הלבנת הון, שוחד ועבירות ניירות ערך. ליווי דיסקרטי מהחקירה הראשונה, על ידי עורך דין בכיר בליטיגציה מורכבת."
  path="/white-collar/"
  crumbTitle="צווארון לבן"
  heroTitle="עבירות צווארון לבן"
  heroSubtitle="כשהקריירה, המוניטין והחירות על הכף - נדרשת הגנה שיודעת לקרוא מאזנים באותה רמה שהיא קוראת כתבי אישום."
  faq={faq}
  ctaTitle="חקירה כלכלית בפתח?"
  ctaText="ההחלטות של הימים הראשונים מלוות את התיק עד סופו. שיחת ייעוץ דיסקרטית - לפני שאתם מדברים עם אף גורם אחר."
>
  <h2>הגנה בעבירות כלכליות - משחק של פרטים ואסטרטגיה</h2>
  <p>
    תיקי <strong>צווארון לבן</strong> שונים מכל תיק פלילי אחר: הם נבנים על
    הררי מסמכים, חוות דעת חשבונאיות ושחזור של שנות פעילות עסקית. מול הנאשם
    עומדות יחידות חקירה ייעודיות - רשות המסים, רשות ניירות ערך, להב 433 -
    שמגיעות לחקירה אחרי חודשים של איסוף ראיות.
  </p>
  <p>
    ההגנה האפקטיבית חייבת להיות יסודית באותה מידה: שליטה מלאה בחומר, הבנה
    פיננסית עמוקה, וניהול אסטרטגי של כל שלב - מהחקירה הראשונה ועד ההכרעה.
    זו בדיוק הליטיגציה המורכבת שהמשרד מתמחה בה.
  </p>

  <h2>תחומי הטיפול</h2>
  <ul>
    <li><strong>מרמה, הונאה וזיוף</strong> - כלפי אנשים פרטיים, תאגידים ורשויות</li>
    <li><strong>עבירות מס</strong> - העלמות מס, חשבוניות פיקטיביות, הליכי כופר</li>
    <li><strong>הלבנת הון</strong> - לרבות תפיסות וחילוטי כספים ונכסים</li>
    <li><strong>שוחד והפרת אמונים</strong> - במגזר הציבורי והפרטי</li>
    <li><strong>עבירות ניירות ערך</strong> - תרמית בניירות ערך, שימוש במידע פנים, דיווחים</li>
    <li><strong>עבירות מנהלים</strong> - אחריות נושאי משרה בתאגידים</li>
  </ul>

  <h2>השלבים הקריטיים בתיק כלכלי</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>שלב</th>
          <th>למה הוא קריטי</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>לפני החקירה</td>
          <td>ייעוץ מוקדם קובע את קו ההגנה - ומונע טעויות שאין מהן דרך חזרה</td>
        </tr>
        <tr>
          <td>חקירה ותפיסות</td>
          <td>ליווי צמוד, טיפול בעיקולים, בתפיסות מחשבים וחשבונות ובצווי איסור פרסום</td>
        </tr>
        <tr>
          <td>שימוע</td>
          <td>ההזדמנות המרכזית לסגור את התיק או לצמצם אישומים - לפני שהם מוגשים</td>
        </tr>
        <tr>
          <td>ניהול המשפט</td>
          <td>חקירת מומחים, התמודדות עם ראיות פיננסיות מורכבות וניהול הגנה סדור</td>
        </tr>
        <tr>
          <td>השלכות נלוות</td>
          <td>מזעור פגיעה במוניטין, ברישיונות, בכהונות ובנכסים</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>דיסקרטיות כערך עליון</h2>
  <p>
    בתיקים כלכליים, עצם קיומה של חקירה יכול לפגוע בעסק ובמוניטין עוד לפני כל
    הכרעה. אנחנו פועלים בדיסקרטיות מלאה, כולל טיפול בצווי איסור פרסום
    כשנדרש, ושומרים על ההתנהלות צמודה ושקטה ככל האפשר.
  </p>
  <p>
    מוזמנים לקרוא גם על הייצוג שלנו ב<a href="/criminal-law/">משפט הפלילי הכללי</a>,
    או <a href="/contact/">לפנות אלינו ישירות</a> לשיחה דיסקרטית.
  </p>
</ServicePage>
