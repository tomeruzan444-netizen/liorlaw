---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "האם פוסט-טראומה מוכרת כפגיעה על ידי משרד הביטחון?",
    a: "כן. הפרעת דחק פוסט-טראומטית (PTSD) שנגרמה עקב אירועים בשירות הצבאי או הביטחוני מוכרת כפגיעה לכל דבר, ומקנה זכאות לתגמולים, לטיפולים ולליווי שיקומי - בדיוק כמו פגיעה גופנית.",
  },
  {
    q: "האירוע קרה לפני שנים ורק עכשיו התפרצו התסמינים. עדיין אפשר לתבוע?",
    a: "כן, ובמקרים רבים דווקא כך זה קורה - פוסט-טראומה יכולה להתפרץ שנים אחרי האירוע, לעיתים בעקבות טריגר. הפסיקה מכירה בכך, אולם ככל שחולף הזמן נדרשת עבודה ראייתית יסודית יותר לקשירת התסמינים לאירועי השירות. אל תוותרו מראש - פנו לבדיקה של המקרה.",
  },
  {
    q: "אין לי תיעוד על האירוע הטראומטי. מה עושים?",
    a: "היעדר תיעוד בזמן אמת הוא מצב שכיח - חיילים רבים לא פנו לגורמי בריאות הנפש במהלך השירות. ניתן לבסס את התיק באמצעים אחרים: עדויות של מפקדים וחברים לשירות, יומני מבצעים, תיעוד יחידתי, ותיעוד רפואי מאוחר שמשקף את התפתחות התסמינים.",
  },
  {
    q: "איך נקבעת דרגת הנכות בפוסט-טראומה?",
    a: "ועדה רפואית שבה יושב פסיכיאטר בוחנת את עוצמת התסמינים ואת מידת הפגיעה בתפקוד - בעבודה, במשפחה ובחיי היומיום. הדרגה נקבעת לפי מבחני הנכות לפגיעות נפשיות, ולהכנה לוועדה ולאופן הצגת הדברים יש משקל של ממש בתוצאה.",
  },
  {
    q: "האם הפנייה והטיפול דיסקרטיים?",
    a: "לחלוטין. כל פנייה מטופלת בדיסקרטיות מלאה, והמידע אינו מועבר לאיש ללא הסכמתכם. אנחנו מבינים את הרגישות - גם מול משפחה ומקום עבודה - ומלווים בהתאם.",
  },
];
---

<ServicePage
  title="עורך דין פוסט טראומה (PTSD) | הכרה בנפגעי טראומה בשירות - ליאור עייש"
  description="ליווי משפטי רגיש ומקצועי להכרה בפוסט-טראומה עקב שירות צבאי: מתי PTSD מוכר כפגיעה, איך מוכיחים קשר לשירות גם שנים אחרי, ומה חשוב לדעת לפני הוועדה הרפואית."
  path="/ptsd-lawyer/"
  crumbTitle="עורך דין פוסט טראומה"
  heroTitle="עורך דין פוסט טראומה"
  heroSubtitle="הפצע לא תמיד נראה - אבל הוא אמיתי, והחוק מכיר בו. ליווי דיסקרטי ורגיש להכרה ב-PTSD עקב השירות."
  faq={faq}
  ctaTitle="מתמודדים עם פוסט-טראומה מהשירות?"
  ctaText="אתם לא לבד, ואתם לא צריכים להוכיח לבד. שיחה ראשונה - דיסקרטית, אנושית וללא התחייבות."
>
  <h2>פוסט-טראומה היא פגיעה לכל דבר</h2>
  <p>
    <strong>הפרעת דחק פוסט-טראומטית (PTSD)</strong> היא פגיעה נפשית שנגרמת
    מחשיפה לאירוע טראומטי - קרב, פיגוע, תאונה קשה, אובדן חברים או חשיפה
    מתמשכת למראות קשים. כשהיא נגרמת עקב השירות, היא מקנה זכאות להכרה
    ולתגמולים ממשרד הביטחון, בדיוק כמו פגיעה גופנית.
  </p>
  <p>
    ובכל זאת, תיקי פוסט-טראומה הם מהמורכבים ביותר בתחום: הפגיעה אינה נראית
    בצילום רנטגן, התיעוד לרוב חסר, והשאלה המרכזית - הקשר בין המצב הנפשי לבין
    אירועי השירות - דורשת עבודה משפטית ורפואית מדויקת.
  </p>

  <h2>סימנים שכדאי לא להתעלם מהם</h2>
  <ul>
    <li>פלשבקים, סיוטים או מחשבות חודרניות על אירועים מהשירות</li>
    <li>הימנעות ממקומות, מאנשים או ממצבים שמזכירים את האירוע</li>
    <li>דריכות מתמדת, קפיצה מרעשים, קושי בשינה ובריכוז</li>
    <li>התפרצויות זעם, ניתוק רגשי או התרחקות מהמשפחה ומחברים</li>
    <li>פגיעה מתמשכת בתפקוד - בעבודה, בלימודים או בזוגיות</li>
  </ul>
  <p>
    אם חלק מהתיאורים האלה מוכר לכם - שווה לבדוק את זכאותכם. הכרה אינה רק
    תגמול כספי; היא פותחת דלת לטיפול ממומן ולליווי שיקומי.
  </p>

  <h2>איך מוכיחים קשר בין ה-PTSD לשירות?</h2>
  <p>שלושה נדבכים בונים תיק פוסט-טראומה חזק:</p>
  <ul>
    <li>
      <strong>האירוע</strong> - תיעוד או עדויות לאירוע הטראומטי: יומני מבצעים,
      דו"חות יחידתיים, עדויות מפקדים וחברים לנשק.
    </li>
    <li>
      <strong>האבחנה</strong> - חוות דעת פסיכיאטרית סדורה שמאבחנת PTSD לפי
      הקריטריונים המקובלים ומתעדת את עוצמת התסמינים.
    </li>
    <li>
      <strong>הקשר הסיבתי</strong> - הנמקה רפואית-משפטית שקושרת את התסמינים
      לאירועי השירות, גם כשההתפרצות מאוחרת.
    </li>
  </ul>

  <h2>למה חשוב ליווי שמבין טראומה?</h2>
  <p>
    ההליך עצמו - מילוי טפסים, שחזור האירוע, ישיבה מול <a href="/medical-committee/">ועדה רפואית</a> -
    עלול בעצמו להציף את הטראומה. הליווי שלנו בנוי בהתאם: אתם משתפים בקצב שלכם,
    אנחנו דואגים שלא תצטרכו לספר את הסיפור יותר פעמים מהנדרש, ומכינים אתכם
    היטב לכל שלב כדי שלא תופתעו. במקרה של דחייה, נלווה אתכם גם
    ב<a href="/pension-officer-appeal/">ערעור על החלטת קצין התגמולים</a>.
  </p>
  <p>
    למידע רחב יותר על ההליך כולו, קראו על
    <a href="/mod-claims/">תביעות נגד משרד הביטחון</a>, או
    <a href="/contact/">פנו אלינו לשיחה דיסקרטית</a>.
  </p>
</ServicePage>
