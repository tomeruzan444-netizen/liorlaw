---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "מי נחשב נפגע פעולות איבה?",
    a: "מי שנפגע בגוף או בנפש מפעולת טרור או איבה - פיגוע, ירי, נפילת רקטה, פיגוע דריסה ועוד - וכן בני משפחה של מי שנהרגו בפעולת איבה. ההכרה נעשית על ידי הרשות המאשרת במשרד הביטחון, והזכויות משולמות באמצעות המוסד לביטוח לאומי.",
  },
  {
    q: "נפגעתי נפשית מאירוע ביטחוני בלי פגיעה גופנית. האם אני זכאי?",
    a: "כן. חרדה, פוסט-טראומה ופגיעות נפשיות אחרות בעקבות אירוע איבה מוכרות גם ללא פגיעה פיזית. גם מי שנכחו באירוע או בקרבתו ופיתחו תסמינים נפשיים עשויים להיות זכאים להכרה ולטיפול.",
  },
  {
    q: "מה מקבלים לאחר ההכרה כנפגע פעולות איבה?",
    a: "בהתאם לדרגת הנכות: תגמול חודשי או מענק חד-פעמי, מימון טיפולים רפואיים ונפשיים, שיקום מקצועי, והטבות נוספות. בני משפחה שכולים זכאים לתגמולים ולליווי מכוח חוק משפחות החיילים שנספו במערכה ונפגעי האיבה.",
  },
  {
    q: "כמה זמן יש להגיש תביעת נפגעי איבה?",
    a: "את התביעה יש להגיש למוסד לביטוח לאומי מוקדם ככל האפשר. הגשה מאוחרת עלולה לפגוע בזכאות רטרואקטיבית ולהקשות על הוכחת הקשר בין הפגיעה לאירוע. אם עבר זמן - אל תניחו שאיחרתם; בואו נבדוק יחד.",
  },
  {
    q: "התביעה נדחתה או שדרגת הנכות נמוכה מדי. מה עושים?",
    a: "ניתן לערור על החלטות הוועדה הרפואית בפני ועדת עררים, ובשאלות משפטיות אף לערער לבית הדין לעבודה. רבים מהתיקים משתפרים משמעותית בשלב הערר כשמגיעים אליו עם חוות דעת וטיעון סדור.",
  },
];
---

<ServicePage
  title="נפגעי פעולות איבה - מיצוי זכויות | ליאור עייש - משרד עורכי דין"
  description="נפגעתם בפיגוע או באירוע ביטחוני? כל הזכויות של נפגעי פעולות איבה ובני משפחותיהם: הליך ההכרה מול הרשות המאשרת והביטוח הלאומי, תגמולים, טיפולים - וליווי משפטי מלא."
  path="/terror-victims/"
  crumbTitle="נפגעי פעולות איבה"
  heroTitle="נפגעי פעולות איבה"
  heroSubtitle="נפגעתם בפיגוע או באירוע ביטחוני - בגוף או בנפש? המדינה חבה לכם הכרה, טיפול ופיצוי. אנחנו נדאג שתקבלו אותם."
  faq={faq}
  ctaTitle="נפגעתם באירוע איבה?"
  ctaText="גם פגיעה נפשית בלבד מזכה בהכרה. ספרו לנו מה קרה - ונכוון אתכם לזכויות המגיעות לכם, ללא עלות בשלב הראשון."
>
  <h2>מהי הכרה כנפגע פעולות איבה?</h2>
  <p>
    מי שנפגעו מפעולת טרור או איבה - בפיגוע, בירי, בנפילת רקטה או בכל אירוע
    עוין אחר - זכאים להכרה ולפיצוי מהמדינה מכוח
    <strong>חוק התגמולים לנפגעי פעולות איבה</strong>. הזכאות חלה על הנפגעים
    עצמם - בגוף או בנפש - וגם על בני משפחותיהם של מי שנספו.
  </p>
  <p>
    ההליך מתנהל בשני מסלולים מקבילים:
    <strong>הרשות המאשרת</strong> במשרד הביטחון קובעת שהאירוע אכן מהווה פעולת
    איבה, ו<strong>המוסד לביטוח לאומי</strong> קובע את דרגת הנכות ומשלם את
    התגמולים. פנייה נכונה לשני הגורמים - עם התיעוד הנכון - חוסכת חודשים של
    עיכובים.
  </p>

  <h2>אילו זכויות מוקנות לנפגעים מוכרים?</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>תחום</th>
          <th>הזכאות</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>תגמול כספי</td>
          <td>תגמול חודשי לפי דרגת הנכות, או מענק חד-פעמי בדרגות נמוכות</td>
        </tr>
        <tr>
          <td>טיפול רפואי</td>
          <td>מימון מלא של טיפולים, תרופות, אשפוזים ומכשירים רפואיים הקשורים לפגיעה</td>
        </tr>
        <tr>
          <td>טיפול נפשי</td>
          <td>מימון פסיכותרפיה וטיפול פסיכיאטרי - גם לנפגעי חרדה ללא פגיעה פיזית</td>
        </tr>
        <tr>
          <td>שיקום</td>
          <td>שיקום מקצועי, לימודים, הכשרות וסיוע בהשתלבות בתעסוקה</td>
        </tr>
        <tr>
          <td>בני משפחה</td>
          <td>תגמולים וליווי לאלמנות/אלמנים, יתומים והורים שכולים</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>גם פגיעה נפשית מזכה בהכרה</h2>
  <p>
    רבים אינם יודעים זאת: מי שנכחו באירוע איבה ופיתחו <strong>חרדה או
    פוסט-טראומה</strong> - גם בלי שריטה אחת - זכאים לפנות להכרה. התסמינים
    מופיעים לעיתים שבועות וחודשים אחרי האירוע. אם אתם מזהים אצלכם או אצל בן
    משפחה תסמינים כאלה, קראו גם על <a href="/ptsd-lawyer/">הכרה בפוסט-טראומה</a>
    ופנו לבדיקה של זכאותכם.
  </p>

  <h2>איך אנחנו עוזרים</h2>
  <ul>
    <li>בדיקת זכאות ומיפוי מלא של הזכויות - לנפגע ולבני המשפחה</li>
    <li>הגשת התביעה לביטוח הלאומי וליווי מול הרשות המאשרת</li>
    <li>הכנה מקצועית ל<a href="/medical-committee/">וועדה הרפואית</a> וייצוג בה</li>
    <li>ערר על החלטות - כשדרגת הנכות אינה משקפת את הפגיעה האמיתית</li>
    <li>ליווי רגיש ודיסקרטי, מתוך הבנה שמדובר בתקופה קשה ממילא</li>
  </ul>
  <p>
    לשאלות או לבדיקת זכאות - <a href="/contact/">צרו קשר</a> ונחזור אליכם
    בהקדם.
  </p>
</ServicePage>
