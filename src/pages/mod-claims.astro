---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "מי זכאי להגיש תביעה נגד משרד הביטחון?",
    a: "חיילים בשירות סדיר, אנשי קבע, מילואימניקים, שוטרים, סוהרים ואנשי כוחות ביטחון נוספים, שנפגעו בגוף או בנפש במהלך השירות ועקב השירות. גם החמרה של מצב רפואי קודם עשויה להקנות זכאות חלקית.",
  },
  {
    q: "מה ההבדל בין תביעה למשרד הביטחון לבין תביעה לביטוח הלאומי?",
    a: "פגיעה שאירעה עקב השירות הצבאי מטופלת על ידי אגף השיקום במשרד הביטחון מכוח חוק הנכים. פגיעות שאינן קשורות לשירות, וכן פגיעות איבה, מטופלות במוסד לביטוח לאומי. לא ניתן לקבל כפל תגמולים בגין אותה פגיעה, ולכן בחירת המסלול הנכון היא החלטה אסטרטגית חשובה.",
  },
  {
    q: "תוך כמה זמן חייבים להגיש את התביעה?",
    a: "ככלל, בתוך שלוש שנים ממועד השחרור מהשירות. לגבי מחלות שהתפרצו מאוחר יותר או פגיעות נפשיות קיימים חריגים בפסיקה - אך ככל שממתינים, קשה יותר להוכיח את הקשר לשירות. מומלץ לפנות לייעוץ מיד כשעולה חשד לקשר בין המצב הרפואי לשירות.",
  },
  {
    q: "כמה זמן אורך הליך ההכרה?",
    a: "הטיפול בתביעה אורך בדרך כלל בין מספר חודשים לשנה ויותר, בהתאם למורכבות הרפואית ולעומס באגף השיקום. הכנה יסודית של התיק מראש - תיעוד מלא וחוות דעת סדורה - מקצרת התדיינויות מיותרות וחוסכת סבבי השלמות מסמכים.",
  },
  {
    q: "מה קורה אם התביעה נדחית?",
    a: "דחייה אינה סוף הדרך. ניתן להגיש ערעור לוועדת ערעורים לפי חוק הנכים בתוך המועד הקבוע בחוק. חלק גדול מהדחיות נובע מחוסר בתשתית רפואית - פער שניתן להשלים בשלב הערעור.",
  },
];
---

<ServicePage
  title='תביעות נגד משרד הביטחון | הכרה כנכה צה"ל - ליאור עייש'
  description='מדריך מקיף לתביעה נגד משרד הביטחון: מי זכאי להכרה כנכה צה"ל, שלבי ההליך מול אגף השיקום, מועדים קריטיים וטעויות נפוצות. ליווי משפטי צמוד משלב ההגשה ועד ההכרה.'
  path="/mod-claims/"
  crumbTitle="תביעות נגד משרד הביטחון"
  heroTitle="תביעות נגד משרד הביטחון"
  heroSubtitle='נפגעתם במהלך השירות? כך תגישו תביעה להכרה כנכי צה"ל - נכון, מבוסס ובזמן.'
  faq={faq}
  ctaTitle="נפגעתם בשירות? אל תתמודדו עם המערכת לבד"
  ctaText="שיחת ייעוץ ראשונית ללא עלות - נבחן את המסמכים שלכם וניתן הערכה כנה של סיכויי התיק."
>
  <h2>מהי תביעה נגד משרד הביטחון?</h2>
  <p>
    <strong>תביעה נגד משרד הביטחון</strong> היא בקשה להכרה בפגיעה בגוף או בנפש
    שנגרמה <strong>במהלך השירות ועקב השירות</strong> - צבאי או ביטחוני. תביעה
    שמתקבלת מקנה מעמד של נכה צה"ל, ועימו תגמולים חודשיים, טיפולים רפואיים,
    ליווי שיקומי והטבות נלוות מאגף השיקום.
  </p>
  <p>
    ההליך מתנהל מול <strong>קצין התגמולים</strong> באגף השיקום של משרד הביטחון,
    מכוח חוק הנכים (תגמולים ושיקום). זהו הליך משפטי-רפואי לכל דבר: ההחלטות
    מתקבלות על סמך ראיות, תיעוד וחוות דעת - ולא על סמך תחושת צדק בלבד.
  </p>

  <blockquote>
    <p>תביעה מנוצחת נבנית לפני שהיא מוגשת - לא אחרי שהיא נדחית.</p>
  </blockquote>

  <h2>מי זכאי להגיש תביעה?</h2>
  <ul>
    <li>חיילים בשירות סדיר ובקבע</li>
    <li>משרתי מילואים - לרבות פגיעה בתקופת שירות מילואים פעיל</li>
    <li>שוטרים, סוהרים, לוחמי אש ואנשי כוחות ביטחון נוספים</li>
    <li>מי שמחלה קיימת שלהם <strong>הוחמרה</strong> עקב תנאי השירות</li>
    <li>מי שנפגעו נפשית - לרבות <a href="/ptsd-lawyer/">פוסט-טראומה (PTSD)</a> - בעקבות אירועי שירות</li>
  </ul>

  <h2>שלבי ההליך - מה צפוי לכם</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>שלב</th>
          <th>מה קורה בו</th>
          <th>נקודות קריטיות</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1. הגשת התביעה</td>
          <td>מילוי טופס תביעה וצירוף תיעוד רפואי ושירותי</td>
          <td>ניסוח האירוע והקשר לשירות - הבסיס לכל התיק</td>
        </tr>
        <tr>
          <td>2. בדיקת קצין התגמולים</td>
          <td>בחינת הקשר בין הפגיעה לשירות, לעיתים באמצעות יועצים רפואיים</td>
          <td>חוות דעת רפואית עצמאית מטעמכם משנה את התמונה</td>
        </tr>
        <tr>
          <td>3. ועדה רפואית</td>
          <td>קביעת דרגת הנכות לפי מבחני הנכות</td>
          <td>הכנה נכונה לוועדה קובעת את גובה התגמולים</td>
        </tr>
        <tr>
          <td>4. החלטה ותגמולים</td>
          <td>קביעת הזכאות, תשלום רטרואקטיבי והטבות נלוות</td>
          <td>בדיקה שדרגת הנכות משקפת את מלוא הפגיעות</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>הטעויות הנפוצות - ולמה כדאי ליווי משפטי מההתחלה</h2>
  <ul>
    <li><strong>הגשה ללא תשתית רפואית</strong> - תביעה "רזה" שנדחית מקשה גם על הערעור שאחריה.</li>
    <li><strong>ניסוח לא מדויק של האירוע</strong> - גרסה שנמסרת בתביעה מחייבת; סתירות בהמשך פוגעות באמינות.</li>
    <li><strong>איחור במועדים</strong> - חלוף הזמן שוחק ראיות ועלול לחסום את התביעה כליל.</li>
    <li><strong>הגעה לוועדה רפואית ללא הכנה</strong> - דקות ספורות בוועדה מכריעות שנים של תגמולים. מומלץ לקרוא על <a href="/medical-committee/">ייצוג בוועדות רפואיות</a>.</li>
    <li><strong>ויתור אחרי דחייה</strong> - במקום לבחון <a href="/pension-officer-appeal/">ערעור על החלטת קצין התגמולים</a> שסיכוייו טובים.</li>
  </ul>

  <h2>איך אנחנו מלווים אתכם</h2>
  <p>
    הליווי שלנו מתחיל הרבה לפני ההגשה: אנחנו ממפים את האירועים, אוספים כל פיסת
    תיעוד רלוונטית - רפואית ושירותית - ומפנים אתכם למומחים הרפואיים הנכונים.
    את התביעה אנחנו בונים כך שתעמוד גם במבחן של ערעור, ומלווים אתכם אישית בכל
    ועדה ובכל דיון, עד למיצוי מלא של הזכויות.
  </p>
  <p>
    יש לכם שאלה על המקרה שלכם? <a href="/contact/">דברו איתנו</a> - שיחת הייעוץ
    הראשונית אינה כרוכה בעלות או בהתחייבות.
  </p>
</ServicePage>
