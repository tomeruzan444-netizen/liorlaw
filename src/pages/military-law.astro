---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "זומנתי לחקירת מצ\"ח. האם מותר לי להתייעץ עם עורך דין לפני?",
    a: "בהחלט - וזו הזכות החשובה ביותר שלכם. חקירת מצ\"ח מתנהלת ככל חקירה פלילית, ומה שנאמר בה מחייב. אל תיכנסו לחדר החקירות לפני שיחת ייעוץ, גם אם נאמר לכם ש'זה רק בירור'. שיחה מוקדמת איתנו יכולה לקבוע את גורל התיק.",
  },
  {
    q: "מה ההבדל בין דין משמעתי לבין בית דין צבאי?",
    a: "דין משמעתי הוא הליך מהיר בפני קצין שיפוט, בעבירות קלות יחסית, והעונשים בו מוגבלים. בית דין צבאי הוא ערכאה שיפוטית לכל דבר, שדנה בעבירות חמורות - והרשעה בו יכולה לגרור מאסר ורישום פלילי. לעיתים יש משמעות אסטרטגית גדולה לשאלה באיזה מסלול יתברר התיק.",
  },
  {
    q: "מה עושים במקרה של עריקות או נפקדות?",
    a: "ככל שמסדירים את החזרה מוקדם יותר ובאופן יזום - כך התוצאה טובה יותר. אנחנו מלווים חיילים ומשפחות בהסדרת התייצבות, בייצוג בהליך ובמזעור הענישה, כולל טיפול בנסיבות אישיות ורפואיות שהובילו להיעדרות.",
  },
  {
    q: "אפשר לערער על קביעה רפואית של הצבא (פרופיל)?",
    a: "כן. קביעות רפואיות של גורמי הרפואה בצה\"ל - פרופיל, כשירות לשירות, התאמה לתפקיד - ניתנות להשגה ולערעור בוועדות הרפואיות הצבאיות. אנחנו מלווים את ההליך מהכנת התיעוד הרפואי ועד הדיון בוועדה.",
  },
  {
    q: "במה שונה ייצוג על ידי מי ששירת בפרקליטות הצבאית?",
    a: "הדין הצבאי הוא עולם סגור עם כללים, נהלים ודינמיקה משלו. עו\"ד ליאור עייש שירת בו למעלה מעשור בדרגת סגן אלוף - כסגן התובע הצבאי הראשי, פרקליט מחוז מטכ\"ל והפרקליט לעניינים מבצעיים. הוא מכיר את השיקולים של התביעה הצבאית מבפנים, ויודע בדיוק מתי ואיך אפשר להשפיע על ההחלטות.",
  },
];
---

<ServicePage
  title="דיני צבא וביטחון | עורך דין צבאי - לשעבר סגן התובע הצבאי הראשי"
  description='עורך דין צבאי בכיר: ייצוג בחקירות מצ"ח, בתי דין צבאיים, עריקות ונפקדות, דין משמעתי, ערעור על פרופיל וקביעות רפואיות. עו"ד ליאור עייש - למעלה מעשור בפרקליטות הצבאית.'
  path="/military-law/"
  crumbTitle="דיני צבא וביטחון"
  heroTitle="דיני צבא וביטחון"
  heroSubtitle='חקירות מצ"ח, בתי דין צבאיים, עריקות והסדרי מעמד - ייצוג על ידי מי שניהל את המערכת הזו מבפנים.'
  faq={faq}
  ctaTitle="מתמודדים עם הליך צבאי?"
  ctaText="אל תתמודדו עם המערכת הצבאית לבד - במיוחד כשאפשר להיעזר במי שהגיע מתוכה. שיחה ראשונה ללא התחייבות."
>
  <h2>העולם המשפטי הצבאי - מגרש ביתי שלנו</h2>
  <p>
    הדין הצבאי הוא מערכת משפט נפרדת: חוק שיפוט צבאי משלה, ערכאות משלה, תביעה
    צבאית משלה ושיקולים ייחודיים של צורכי הצבא. מי שמגיע אליה בלי היכרות
    עמוקה - מגלה מהר שהכללים שונים מהעולם האזרחי.
  </p>
  <p>
    <strong>עו"ד ליאור עייש</strong> שירת בעולם הזה למעלה מעשור, בדרגת סגן
    אלוף, בתפקידי מפתח בפרקליטות הצבאית ובסנגוריה הצבאית: סגן התובע הצבאי
    הראשי, פרקליט מחוז מטכ"ל והפרקליט לעניינים מבצעיים. הידע הזה עובד היום
    עבור הלקוחות שלנו.
  </p>

  <h2>במה אנחנו מטפלים?</h2>
  <ul>
    <li><strong>חקירות מצ"ח</strong> - ייעוץ לפני חקירה, ליווי צמוד לאורכה והתמודדות עם תוצאותיה</li>
    <li><strong>בתי דין צבאיים</strong> - ייצוג בכל הערכאות, מהמחוזי ועד בית הדין הצבאי לערעורים</li>
    <li><strong>עריקות ונפקדות</strong> - הסדרת התייצבות יזומה ומזעור ענישה</li>
    <li><strong>דין משמעתי</strong> - ייעוץ וליווי בהליכים בפני קציני שיפוט</li>
    <li><strong>עבירות מבצעיות ורשלנות</strong> - תחום שבו שירת עו"ד עייש כפרקליט לעניינים מבצעיים</li>
    <li><strong>ערעור על קביעות רפואיות</strong> - פרופיל, כשירות והתאמה לשירות</li>
    <li><strong>הסדרי מעמד מול הצבא</strong> - דחיות שירות, פטורים והתאמות</li>
    <li>וכן <a href="/mod-claims/">תביעות מול משרד הביטחון</a> על פגיעות שאירעו בשירות</li>
  </ul>

  <h2>ההבדל בין ההליכים - במבט אחד</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>הליך</th>
          <th>מי דן</th>
          <th>מה על הכף</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>דין משמעתי</td>
          <td>קצין שיפוט</td>
          <td>ריתוק, נזיפה, מחבוש קצר - ללא רישום פלילי</td>
        </tr>
        <tr>
          <td>בית דין צבאי</td>
          <td>שופטים צבאיים</td>
          <td>מאסר, הורדה בדרגה, רישום פלילי</td>
        </tr>
        <tr>
          <td>ועדה רפואית צבאית</td>
          <td>גורמי רפואה מוסמכים</td>
          <td>פרופיל, כשירות והמשך השירות</td>
        </tr>
        <tr>
          <td>הליכי מטה</td>
          <td>גורמי כוח אדם</td>
          <td>מעמד, שיבוץ, דחייה או פטור</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>גם למשרתי קבע ולאנשי מילואים</h2>
  <p>
    אנחנו מלווים גם אנשי קבע בהליכים פיקודיים ומשמעתיים שמאיימים על הקריירה,
    ומשרתי מילואים שנקלעו להליך בעקבות שירותם. אם נפגעתם במהלך השירות - בגוף
    או בנפש - קראו גם על <a href="/mod-claims/">הכרה כנכי צה"ל</a> ועל
    <a href="/ptsd-lawyer/">הכרה בפוסט-טראומה</a>.
  </p>
  <p>
    ההליך כבר התחיל? הזמן עובד נגדכם - <a href="/contact/">דברו איתנו עוד היום</a>.
  </p>
</ServicePage>
