---
import ServicePage from "../layouts/ServicePage.astro";

const faq = [
  {
    q: "האם מותר להגיע לוועדה רפואית עם עורך דין?",
    a: "כן. יש לכם זכות מלאה להתייצב לוועדה עם מלווה - לרבות עורך דין - שידאג שהוועדה תשמע את מלוא התלונות, תבדוק כראוי ותתעד את הממצאים. נוכחות מקצועית משנה את הדינמיקה בחדר.",
  },
  {
    q: "איך כדאי להתכונן לוועדה רפואית?",
    a: "מרכזים את כל התיעוד הרפואי העדכני, מכינים מראש תיאור מסודר של המגבלות בחיי היומיום, ולא ממעיטים בתלונות מתוך נימוס או הרגל. אנחנו עוברים עם כל לקוח על מהלך הוועדה הצפוי ועל השאלות שיישאלו - כך שלא תופתעו בפנים.",
  },
  {
    q: "מה ההבדל בין נכות רפואית לאי-כושר בביטוח הלאומי?",
    a: "הנכות הרפואית משקפת את הליקוי הרפואי עצמו באחוזים; דרגת אי-הכושר משקפת עד כמה הליקוי פוגע ביכולת להשתכר. קצבת נכות כללית נקבעת משילוב של שניהם - ולכן חשוב להציג נכון לא רק את האבחנות, אלא גם את ההשפעה התפקודית.",
  },
  {
    q: "קיבלתי אחוזי נכות נמוכים מדי. אפשר לערור?",
    a: "כן. על החלטת ועדה רפואית ניתן להגיש ערר לוועדה רפואית לעררים בתוך המועד הקבוע, ועל החלטת ועדת העררים ניתן לערער בשאלות משפטיות לבית הדין לעבודה. חשוב לבסס את הערר על נימוקים קונקרטיים - לא רק על תחושת אי-צדק.",
  },
  {
    q: "האם כדאי להביא חוות דעת רפואית פרטית לוועדה?",
    a: "במקרים רבים - בהחלט. חוות דעת של מומחה מטעמכם מחייבת את הוועדה להתייחס אליה באופן מנומק, והיא מסגרת מקצועית שקשה יותר להתעלם ממנה. אנחנו מכווינים לאיזה מומחה לפנות בהתאם לפגיעה.",
  },
];
---

<ServicePage
  title="ייצוג בוועדה רפואית בביטוח לאומי | הכנה וליווי - ליאור עייש"
  description="ועדה רפואית בביטוח הלאומי קובעת את אחוזי הנכות ואת הקצבה שלכם. איך מתכוננים נכון, מה קורה בוועדה, מתי מגישים ערר - וליווי מקצועי שמגיע איתכם עד לחדר הוועדה."
  path="/medical-committee/"
  crumbTitle="ועדה רפואית בביטוח לאומי"
  heroTitle="ייצוג בוועדה רפואית בביטוח לאומי"
  heroSubtitle="דקות ספורות בוועדה קובעות את הקצבה לשנים קדימה. תגיעו מוכנים - ולא לבד."
  faq={faq}
  ctaTitle="זומנתם לוועדה רפואית?"
  ctaText="אל תגיעו לא מוכנים. נעבור איתכם על התיק, נכין אתכם לשאלות - ונתייצב איתכם בוועדה."
>
  <h2>למה הוועדה הרפואית כל כך קריטית?</h2>
  <p>
    הוועדה הרפואית היא הצומת המרכזי של כל תביעת נכות בביטוח הלאומי: היא זו
    שקובעת את <strong>אחוזי הנכות הרפואית</strong> - ומהם נגזרות הקצבה, ההטבות
    והזכאויות הנלוות. בפועל, מפגש של דקות ספורות עם רופאי הוועדה משפיע על
    שנים של זכויות.
  </p>
  <p>
    הבעיה המוכרת: מבוטחים רבים מגיעים לא מוכנים - ממעיטים בתלונות, שוכחים
    מגבלות מהותיות, או לא יודעים שמה שנאמר (ולא נאמר) בחדר נרשם בפרוטוקול
    ומחייב. כאן בדיוק נכנס הליווי המקצועי.
  </p>

  <h2>באילו ועדות אנחנו מלווים?</h2>
  <ul>
    <li>ועדות נכות כללית - קביעת נכות רפואית ודרגת אי-כושר</li>
    <li>ועדות נפגעי עבודה - לאחר הכרה בפגיעה בעבודה</li>
    <li>ועדות <a href="/terror-victims/">נפגעי פעולות איבה</a></li>
    <li>ועדות רפואיות לעררים - כשמערערים על ההחלטה הראשונה</li>
    <li>וכן ועדות רפואיות של אגף השיקום במסגרת <a href="/mod-claims/">תביעה מול משרד הביטחון</a></li>
  </ul>

  <h2>כך נראה ליווי נכון לוועדה</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>שלב</th>
          <th>מה אנחנו עושים</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>לפני הוועדה</td>
          <td>מיפוי התיעוד הרפואי, איתור פערים, הפניה לחוות דעת מומחה במידת הצורך</td>
        </tr>
        <tr>
          <td>הכנה אישית</td>
          <td>סימולציה של הוועדה: מה יישאל, איך מתארים מגבלות תפקוד, ממה להיזהר</td>
        </tr>
        <tr>
          <td>בוועדה עצמה</td>
          <td>התייצבות לצדכם, הצגת עיקרי התיק, ווידוא שהתלונות והממצאים נרשמים בפרוטוקול</td>
        </tr>
        <tr>
          <td>אחרי ההחלטה</td>
          <td>ניתוח הפרוטוקול ודרגת הנכות, והגשת ערר מנומק אם ההחלטה אינה משקפת את מצבכם</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>טעויות שכדאי להימנע מהן</h2>
  <ul>
    <li><strong>"להחזיק מעמד" מול הרופאים</strong> - הוועדה מתעדת את מה שהיא רואה; הצגה "גיבורית" של המצב עולה באחוזי נכות.</li>
    <li><strong>להגיע בלי מסמכים עדכניים</strong> - הוועדה מחליטה לפי מה שמונח לפניה, לא לפי מה שקיים אי-שם בתיק הרפואי.</li>
    <li><strong>לוותר על ערר</strong> - המועד קצוב, ורבים מפסידים זכויות רק כי לא ידעו שאפשר להשיג על ההחלטה.</li>
    <li><strong>לחתום ולשכוח</strong> - פרוטוקול הוועדה הוא מסמך משפטי; חשוב לקרוא אותו ולוודא שהוא משקף את מה שנאמר.</li>
  </ul>

  <p>
    זומנתם לוועדה? קיבלתם החלטה שלא נראית לכם?
    <a href="/contact/">דברו איתנו</a> לפני הצעד הבא - ההכוונה הראשונית אינה
    כרוכה בעלות.
  </p>
</ServicePage>
